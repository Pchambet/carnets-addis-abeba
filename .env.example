# =============================================================================
# Carnets d'Addis-Abeba — Variables d'environnement
# Copier vers .env.local pour le développement local
# =============================================================================

# URL publique du site (OpenGraph, sitemap, Cusdis, liens canoniques)
# Vercel définit automatiquement VERCEL_URL en prod ; à configurer pour staging.
NEXT_PUBLIC_SITE_URL=https://carnets-addis-abeba.vercel.app

# Cusdis — Livre d'or / commentaires
# Obtenir l'App ID : dashboard cusdis.com → Settings
NEXT_PUBLIC_CUSDIS_APP_ID=e5deb779-2d3a-4380-a2ca-bec214a584eb
