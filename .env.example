# =============================================================================
# Carnets d'Addis-Abeba — Variables d'environnement
# Copier vers .env.local pour le développement local
# =============================================================================

# URL publique du site (OpenGraph, sitemap, Cusdis, liens canoniques)
# Vercel définit automatiquement VERCEL_URL en prod ; à configurer pour staging.
NEXT_PUBLIC_SITE_URL=https://carnets-addis-abeba.vercel.app

# Protection par mot de passe (pour protéger les photos)
# Code par défaut : 0000. Définir NEXT_PUBLIC_SITE_PASSWORD pour changer.
# Pour désactiver : NEXT_PUBLIC_SITE_UNLOCKED=1
NEXT_PUBLIC_SITE_PASSWORD=0000

# Cusdis — Livre d'or / commentaires (legacy, remplacé par Supabase)
NEXT_PUBLIC_CUSDIS_APP_ID=e5deb779-2d3a-4380-a2ca-bec214a584eb

# Supabase — Livre d'or custom (commentaires, réponses)
# Dashboard : supabase.com → projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Notification email (Resend) — pour les nouveaux commentaires
RESEND_API_KEY=re_xxxx
CLAIRE_EMAIL=claire.stellio@gmail.com
COMMENT_WEBHOOK_SECRET=your-webhook-secret  # optionnel, pour sécuriser le webhook
# RESEND_FROM=Carnets <noreply@tondomaine.com>  # optionnel
